[mysqld]
server-id    = 1
log-bin      = mysql-bin
binlog-format = ROW

# Do NOT filter by database — ensures DDL (CREATE TABLE, DROP DATABASE)
# is always written to the binary log regardless of which database is active.
# Slaves use replicate-do-db which is enough to filter on their side.

binlog_expire_logs_seconds     = 604800
innodb_flush_log_at_trx_commit = 1
sync_binlog                    = 1
